{
  "name": "workbench-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Open-source BullMQ dashboard. Drop-in for any Node backend.",
  "workspaces": [
    "apps/*",
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --parallel",
    "typecheck": "turbo typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "smoke": "bun scripts/smoke.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "turbo": "^2.3.0",
    "typescript": "^5.7.2"
  },
  "packageManager": "bun@1.3.11",
  "engines": {
    "node": ">=18"
  }
}
