{
  "name": "example-with-tanstack-start",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "concurrently -k -n web,worker -c cyan,magenta \"vite dev --port ${PORT:-3000}\" \"tsx watch scripts/worker.ts\"",
    "build": "vite build",
    "start": "concurrently -k -n web,worker -c cyan,magenta \"vite preview --port ${PORT:-3000} --host\" \"tsx scripts/worker.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@getworkbench/tanstack-start": "workspace:*",
    "@tanstack/react-router": "^1.170.8",
    "@tanstack/react-start": "^1.168.14",
    "bullmq": "^5.71.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.0",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^8.0.0"
  }
}
