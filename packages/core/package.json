{
  "name": "@getworkbench/core",
  "version": "0.7.1",
  "description": "Core of Workbench — QueueManager, API router, and bundled UI. Modern alternative to `@bull-board/api`.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./hono": {
      "types": "./dist/hono.d.ts",
      "import": "./dist/hono.js"
    },
    "./ui": {
      "types": "./src/ui/index.ts",
      "default": "./src/ui/index.ts"
    },
    "./ui/styles.css": "./src/ui/styles/globals.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun run clean && bun run build:ui && bun run build:lib",
    "build:lib": "tsup",
    "build:ui": "vite build",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@xyflow/react": "^12.10.1",
    "dagre": "^0.8.5",
    "framer-motion": "^12.38.0",
    "hono": "^4.6.14",
    "lru-cache": "^11.2.7"
  },
  "devDependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-router": "^1.168.4",
    "@types/dagre": "^0.7.54",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.27",
    "bullmq": "^5.71.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "^4.1.0",
    "hono": "^4.6.14",
    "ioredis": "^5.10.1",
    "lucide-react": "^0.468.0",
    "postcss": "^8.5.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.2",
    "recharts": "^2.13.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.5.5",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "bullmq": ">=5.0.0",
    "ioredis": ">=5.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "bullmq",
    "workbench",
    "getworkbench",
    "queue",
    "dashboard",
    "redis",
    "jobs",
    "background-jobs",
    "job-queue",
    "bull-board",
    "bull-board-alternative",
    "@bull-board",
    "monitoring"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pontusab/workbench.git",
    "directory": "packages/core"
  },
  "homepage": "https://getworkbench.dev",
  "license": "MIT"
}
