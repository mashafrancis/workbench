{
  "name": "@getworkbench/mcp",
  "version": "0.5.1",
  "description": "Model Context Protocol server for Workbench — let LLMs inspect and operate BullMQ queues. Alternative to wiring bull-board into your AI workflow.",
  "type": "module",
  "bin": {
    "workbench-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "clean": "rm -rf dist .turbo",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "bullmq",
    "workbench",
    "getworkbench",
    "dashboard",
    "ai",
    "llm",
    "cursor",
    "claude",
    "redis",
    "queue",
    "jobs",
    "background-jobs",
    "bull-board",
    "bull-board-alternative",
    "@bull-board",
    "monitoring"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pontusab/workbench.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://getworkbench.dev",
  "license": "MIT"
}
