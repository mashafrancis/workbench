{
  "name": "@getworkbench/hono",
  "version": "0.7.0",
  "description": "Hono adapter for Workbench — modern BullMQ dashboard, drop-in alternative to `@bull-board/hono`.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@getworkbench/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "bullmq": "^5.71.1",
    "hono": "^4.6.14",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "peerDependencies": {
    "bullmq": ">=5.0.0",
    "hono": ">=4.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "bullmq",
    "workbench",
    "getworkbench",
    "hono",
    "queue",
    "dashboard",
    "redis",
    "jobs",
    "background-jobs",
    "job-queue",
    "bull-board",
    "bull-board-alternative",
    "@bull-board",
    "monitoring"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pontusab/workbench.git",
    "directory": "packages/hono"
  },
  "homepage": "https://getworkbench.dev",
  "license": "MIT"
}
