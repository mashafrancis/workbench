{
  "name": "@getworkbench/cli",
  "version": "0.5.0",
  "description": "One-command setup for Workbench — scaffold a bull-board replacement with `npx @getworkbench/cli init`.",
  "type": "module",
  "bin": {
    "workbench": "./dist/index.js",
    "create-workbench": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "clean": "rm -rf dist .turbo",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@clack/prompts": "^0.8.2",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "bullmq",
    "workbench",
    "getworkbench",
    "cli",
    "scaffold",
    "init",
    "npx",
    "migrate",
    "queue",
    "dashboard",
    "redis",
    "bull-board",
    "bull-board-alternative",
    "@bull-board",
    "monitoring"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pontusab/workbench.git",
    "directory": "packages/cli"
  },
  "homepage": "https://getworkbench.dev",
  "license": "MIT"
}
